[sub_resource type="GDScript" id="GDScript_wdnak"]
script/source = "extends Label
@onready var map_node : Node2D = $\"../../..\"
@onready var terrain_panel : Panel = $\"../\"
@onready var vbox = $\"../VBoxContainer\"
var last_displayed_country = \"\"
var searching = {}

func _process(_delta):
	if Data.player_country == null: return
	for country in Data.country_list.values():
		if country.name == map_node.last_country_clicked:
			if country.name == Data.player_country.name:
				if country.name != last_displayed_country:
					last_displayed_country = country.name
					display_terrain(country)

func display_terrain(country):
	text = \"\"
	var ter = country.terrain
	for child in vbox.get_children():
		child.queue_free()

	var title = Label.new()
	title.text = \"🗺 Terrain Survey\"
	title.add_theme_font_size_override(\"font_size\", 16)
	title.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	title.size_flags_horizontal = Control.SIZE_EXPAND_FILL
	vbox.add_child(title)
	vbox.add_child(HSeparator.new())

	var resources = [
		[\"🛢 Oil\",        \"oil\"],
		[\"⚙ Metal\",      \"metal\"],
		[\"🪨 Coal\",       \"coal\"],
		[\"💨 Gas\",        \"gas\"],
		[\"☢ Uranium\",    \"uranium\"],
		[\"🌾 Food\",       \"food\"],
		[\"⚡ Energy\",     \"energy\"],
		[\"🪵 Wood\",       \"wood\"],
		[\"🪙 Gold\",       \"gold\"],
		[\"💎 Rare Earth\", \"rare_earth\"],
	]

	for entry in resources:
		var label = entry[0]
		var key = entry[1]
		var view_val = ter.get(\"view_\" + key)
		var max_val = ter.get(key)
		if view_val == null: view_val = 0
		if max_val == null: max_val = 0

		var row = HBoxContainer.new()
		row.size_flags_horizontal = Control.SIZE_EXPAND_FILL

		var lbl = Label.new()

		var status = \"???\"
		if view_val == 0:
			status = \"Unexplored\"
		elif view_val >= max_val:
			status = format_number(view_val) + \" (fully surveyed)\"
		else:
			status = format_number(view_val) + \" surveyed\"

		lbl.text = label + \": \" + status
		lbl.size_flags_horizontal = Control.SIZE_EXPAND_FILL
		lbl.add_theme_font_size_override(\"font_size\", 13)

		if view_val == 0:
			lbl.modulate = Color(0.5, 0.5, 0.5)
		elif view_val >= max_val:
			lbl.modulate = Color.GREEN
		else:
			lbl.modulate = Color.YELLOW

		row.add_child(lbl)

		var btn = Button.new()
		if view_val >= max_val:
			btn.text = \"✓\"
			btn.disabled = true
		elif searching.get(key, false):
			btn.text = \"...\"
			btn.disabled = true
		else:
			btn.text = \"🔍\"
		btn.custom_minimum_size = Vector2(35, 0)
		btn.add_theme_font_size_override(\"font_size\", 12)
		btn.pressed.connect(on_resource_pressed.bind(key))
		row.add_child(btn)

		vbox.add_child(row)

	var legend = Label.new()
	legend.text = \"\\n⚠ Surveyed amounts are estimates.\\nTrue reserves are unknown until fully explored.\"
	legend.modulate = Color(0.6, 0.6, 0.6)
	legend.add_theme_font_size_override(\"font_size\", 11)
	legend.autowrap_mode = TextServer.AUTOWRAP_WORD
	vbox.add_child(legend)

func format_number(n) -> String:
	if n == null: return \"0\"
	n = float(n)
	if n >= 1000000:
		return str(snapped(n / 1000000.0, 0.1)).replace(\".0\", \"\") + \"M\"
	elif n >= 1000:
		return str(snapped(n / 1000.0, 0.1)).replace(\".0\", \"\") + \"k\"
	return str(int(n))

func on_resource_pressed(resource_key: String):
	if searching.get(resource_key, false): return
	searching[resource_key] = true
	last_displayed_country = \"\"
	search_resource(resource_key)

func search_resource(resource_key: String):
	var ter = Data.player_country.terrain
	var view_key = \"view_\" + resource_key
	var current_view = ter.get(view_key)
	var max_val = ter.get(resource_key)
	if current_view == null: 
		current_view = 0
	if max_val == null: 
		max_val = 0

	var remaining = max_val - current_view
	if remaining <= 0:
		searching[resource_key] = false
		Data.show_popup(resource_key.capitalize() + \": fully surveyed!\")
		return

	var discovery = int(max_val * randf_range(0.10, 0.20))
	discovery = max(1, discovery)
	var new_value = min(current_view + discovery, max_val)

	if multiplayer.is_server():
		Data.apply_terrain_field.rpc(Data.player_country.name, view_key, new_value)
	else:
		Data.request_set_terrain_field.rpc_id(1, Data.player_country.name, view_key, new_value)

	searching[resource_key] = false
	Data.show_popup(\"🔍 \" + resource_key.replace(\"_\", \" \").capitalize() + \"\\n+\" + format_number(discovery) + \" surveyed\\nTotal known: \" + format_number(new_value) + \"\\n(true reserves unknown)\")
	last_displayed_country = \"\"

func _on_country_close_button_down() -> void:
	terrain_panel.global_position = Vector2(0, 0)
	terrain_panel.hide()
"

